{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESP-IDF: ビルド / Build",
      "type": "shell",
      "command": "${config:idf.pythonBinPath}",
      "args": [
        "${config:idf.espIdfPath}/tools/idf.py",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "IDF_PATH": "${config:idf.espIdfPath}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "ESP-IDF: フラッシュ（XIAO ESP32-S3）/ Flash",
      "type": "shell",
      "command": "${config:idf.pythonBinPath}",
      "args": [
        "${config:idf.espIdfPath}/tools/idf.py",
        "-p", "${config:idf.port}",
        "-b", "460800",
        "--chip", "esp32s3",
        "flash"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "IDF_PATH": "${config:idf.espIdfPath}"
        }
      },
      "group": "build",
      "dependsOn": "ESP-IDF: ビルド / Build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "ESP-IDF: ビルド＋フラッシュ＋モニター / Build Flash Monitor",
      "type": "shell",
      "command": "${config:idf.pythonBinPath}",
      "args": [
        "${config:idf.espIdfPath}/tools/idf.py",
        "-p", "${config:idf.port}",
        "-b", "460800",
        "--chip", "esp32s3",
        "flash",
        "monitor"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "IDF_PATH": "${config:idf.espIdfPath}"
        }
      },
      "group": "build",
      "dependsOn": "ESP-IDF: ビルド / Build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "menuconfig: WiFi SSID・パスワード設定",
      "type": "shell",
      "command": "${config:idf.pythonBinPath}",
      "args": [
        "${config:idf.espIdfPath}/tools/idf.py",
        "menuconfig"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "IDF_PATH": "${config:idf.espIdfPath}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
